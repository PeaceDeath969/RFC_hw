@startuml
title Failover Scenario - Push failure to SMS

actor "Bank Service" as Bank
participant "Notification API" as API
queue "Broker" as Broker
participant "Delivery Orchestrator" as Orch
database "State Store" as DB
participant "Push Adapter" as Push
participant "Push Provider" as PushProvider
participant "SMS Adapter" as SMS
participant "SMS Provider" as SMSProvider

Bank -> API: POST /notifications (transactional)
API -> Broker: publish delivery command
API --> Bank: accepted

Broker -> Orch: delivery command
Orch -> DB: create delivery state = PENDING

Orch -> Push: send(notification)
Push -> PushProvider: provider API request
PushProvider --> Push: timeout / failed
Push --> Orch: FAILED

Orch -> DB: record failed push attempt
Orch -> Orch: choose next channel = SMS

Orch -> SMS: send(notification)
SMS -> SMSProvider: provider API request
SMSProvider --> SMS: DELIVERED
SMS --> Orch: DELIVERED

Orch -> DB: update state = DELIVERED\nsuccess_channel = SMS
Orch -> Orch: mark notification completed\nblock any further attempts
@enduml
